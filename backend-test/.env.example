# backend-test/.env.example
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and edit as needed before starting the test server.
#
# Run:
#   cd backend-test
#   cp .env.example .env
#   uvicorn main:app --host 0.0.0.0 --port 8000 --reload
# ──────────────────────────────────────────────────────────────────────────────

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Face Recognition ──────────────────────────────────────────────────────────
# Use ArcFace (InsightFace) backend — the primary focus of this test harness.
FACE_RECOGNIZER_BACKEND=arcface
ARCFACE_MODEL_NAME=buffalo_l
# Lower = more permissive (more matches); raise to reduce false positives.
ARCFACE_SIMILARITY_THRESHOLD=0.35

# ── Dummy EEG ─────────────────────────────────────────────────────────────────
# Controls what the synthetic EEG pipeline reports for every fixation event.
#   true   — always "unfamiliar" → cue is sent for every known face (default)
#   false  — always "familiar"   → no cue is ever sent
#   random — coin-flip 50/50
DUMMY_EEG_ALWAYS_UNFAMILIAR=true
# Simulated processing delay in seconds (0 = instant).
DUMMY_EEG_DELAY=0.2

# ── Webcam ────────────────────────────────────────────────────────────────────
# OpenCV device index (0 = default/built-in webcam, 1 = second camera, …).
WEBCAM_DEVICE_INDEX=0
# Target capture framerate.
WEBCAM_FPS=15
# JPEG encoding quality sent to the face recognition pipeline.
WEBCAM_JPEG_QUALITY=85

# ── Keyboard / auto-trigger ───────────────────────────────────────────────────
# Set > 0 to auto-fire a fixation event every N seconds (useful for unattended
# testing).  0 = disabled: press Enter in the terminal or POST /test/trigger.
TEST_AUTO_TRIGGER_INTERVAL=0

# ── Cue delivery ──────────────────────────────────────────────────────────────
# false → backend reads settings.json and returns the full cue payload
#         (name, relationship, image URL, audio URL) — best for console output.
# true  → returns only {"people_id": N} and relies on the AR app to load cues.
USE_LOCAL_CUES=false
# Serve media as URLs (relative to PUBLIC_URL) rather than base64 bytes.
USE_URL=true

# ── Face memory / temporal voting ─────────────────────────────────────────────
# How long (seconds) to accumulate face detections before voting on identity.
MEMORY_WINDOW_SECONDS=5.0
MEMORY_MIN_VOTES=2
MEMORY_MAJORITY_RATIO=0.6

# ── Event rate limiting ───────────────────────────────────────────────────────
# Minimum seconds between accepted fixation events.
EVENT_MIN_INTERVAL_S=3.0
